#!/usr/bin/env bash
# GTBI Pre-commit Hook: Auto-regenerate manifest outputs
#
# When gtbi.manifest.yaml or packages/manifest/** change,
# this hook regenerates all manifest-derived outputs and stages the changes.
#
# Install: ./scripts/hooks/install.sh
# Bypass: git commit --no-verify
# CI enforces: bun run generate --diff (blocks merge on drift)

set -euo pipefail

# Check if manifest-related files are staged
if git diff --cached --name-only | grep -qE '^(gtbi\.manifest\.yaml|packages/manifest/)'; then
    echo "📦 Manifest changes detected, regenerating manifest-derived outputs..."

    # Check if bun is available
    if ! command -v bun &>/dev/null; then
        echo "⚠️  bun not found. Skipping auto-regeneration."
        echo "   Run manually: cd packages/manifest && bun run generate"
        exit 0
    fi

    # Regenerate
    (cd packages/manifest && bun install --silent && bun run generate) || {
        echo "❌ Generator failed. Fix issues before committing."
        exit 1
    }

    # Stage regenerated files
    git add scripts/generated/
    if [[ -d apps/web/lib/generated ]]; then
        git add apps/web/lib/generated/
        echo "✅ Regenerated and staged scripts/generated/ and apps/web/lib/generated/"
    else
        echo "✅ Regenerated and staged scripts/generated/"
    fi
fi
